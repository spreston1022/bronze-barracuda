    "/people/{playerId}/stats": {
      "x-zuplo-path": {
        "pathMode": "open-api"
      },
      "get": {
        "operationId": "getPlayerStats",
        "summary": "Get player stats",
        "description": "Returns season stats for a specific player. Requires a player ID — use searchPlayer first.",
        "parameters": [
          {
            "name": "playerId",
            "in": "path",
            "required": true,
            "description": "The MLB player ID, e.g. 660271 for Shohei Ohtani",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "stats",
            "in": "query",
            "required": true,
            "description": "Type of stats. Use 'season' for current season stats.",
            "schema": {
              "type": "string",
              "enum": [
                "season",
                "career",
                "gameLog",
                "yearByYear"
              ]
            }
          },
          {
            "name": "season",
            "in": "query",
            "required": false,
            "description": "Season year, e.g. 2025.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "group",
            "in": "query",
            "required": false,
            "description": "Stat group: 'hitting', 'pitching', or 'fielding'",
            "schema": {
              "type": "string",
              "enum": [
                "hitting",
                "pitching",
                "fielding"
              ]
            }
          }
        ],
        "x-zuplo-route": {
          "corsPolicy": "none",

        "description": "Search for an MLB player by name to get their player ID. Always call this first before getPlayerStats.",
        "parameters": [
          {
            "name": "names",
            "in": "query",
            "required": true,
            "description": "Player name to search for, e.g. 'Shohei Ohtani' or 'Mookie Betts'",

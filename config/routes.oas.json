          },
          "mcp": {
            "type": "tool",
            "name": "getStandings",
            "description": "Returns current MLB standings for all divisions. No parameters required.",
            "annotations": {
              "readOnlyHint": true
            },
            "_meta": {
              "openai/outputTemplate": "ui://widget/mlb-widget.html",
              "openai/toolInvocation/invoking": "Fetching standings...",
              "openai/toolInvocation/invoked": "Standings ready!"
            }
          }
